{
	"name": "frontend",
	"version": "0.0.2",
	"private": true,
	"engines": {
		"node": ">=22 <23"
	},
	"packageManager": "pnpm@10.32.1",
	"pnpm.onlyBuiltDependencies": [
		"@sveltejs/kit",
		"esbuild"
	],
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"start": "node build/index.js",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"pullTypes": "node scripts/pullTypes.js",
		"pullSchema": "node scripts/directus-sync.js pull",
		"pushSchema": "node scripts/directus-sync.js push",
		"diffSchema": "node scripts/directus-sync.js diff"
	},
	"devDependencies": {
		"@directus/sdk": "^19.1.0",
		"@lucide/svelte": "^0.525.0",
		"@lukulent/svelte-umami": "^0.0.4",
		"@sveltejs/adapter-node": "^5.4.0",
		"@sveltejs/kit": "^2.49.3",
		"@sveltejs/vite-plugin-svelte": "6.1.0",
		"@tailwindcss/typography": "^0.5.19",
		"@types/eslint": "^9.6.1",
		"@types/jsonwebtoken": "^9.0.10",
		"autoprefixer": "^10.4.23",
		"bits-ui": "1.3.19",
		"clsx": "^2.1.1",
		"cookie": "^1.1.1",
		"embla-carousel-svelte": "^8.6.0",
		"eslint": "^9.39.2",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.13.1",
		"fluid-tailwind": "^1.0.4",
		"formsnap": "2.0.1",
		"globals": "^16.5.0",
		"jsonwebtoken": "^9.0.3",
		"lucide-svelte": "^0.525.0",
		"mode-watcher": "^1.1.0",
		"prettier": "^3.7.4",
		"prettier-plugin-svelte": "^3.4.1",
		"prettier-plugin-tailwindcss": "^0.6.14",
		"runed": "^0.31.1",
		"svelte": "5.36.6",
		"svelte-check": "^4.3.5",
		"svelte-intersection-observer": "^1.0.0",
		"svelte-sonner": "^1.0.7",
		"sveltekit-embed": "^0.0.22",
		"sveltekit-superforms": "^2.29.1",
		"tailwind-merge": "^2.6.0",
		"tailwind-variants": "^0.3.1",
		"tailwindcss": "^3.4.19",
		"tailwindcss-animate": "^1.0.7",
		"thumbhash": "^0.1.1",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.52.0",
		"vanilla-cookieconsent": "3.1.0",
		"vaul-svelte": "1.0.0-next.7",
		"vite": "^7.3.0",
		"zod": "^4.3.5"
	},
	"type": "module",
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild"
		]
	},
	"dependencies": {
		"@arisbh/dirhover-svelte": "^0.0.5",
		"@arisbh/marqueeck": "^0.5.1",
		"plyr": "^3.8.4",
		"svelte-lenis": "^0.0.5"
	}
}
